{
  "name": "red-account-plan",
  "version": "1.0.0",
  "description": "Upload an Excel account health assessment and generate a 30-60-90 day Customer Success plan to move an account from Red to Yellow to Green.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "customer-success",
    "excel",
    "30-60-90",
    "typescript",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.14.10",
    "@types/pdfkit": "^0.17.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
